@using Library.Domain.Entities
@model Library.MVC.ViewModels.BookDetailsViewModel
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "Bokbibliotek";
    var books = ViewBag.Books as List<BookDetails>;
    var sortBy = ViewBag.SortBy as string ?? "title";
}

<!-- Böcker Container -->
<div class="container-fluid px-4 py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-11">
            <!-- Kreativ Header Sektion -->
            <div class="books-header mb-5 position-relative overflow-hidden">

                <!-- Bakgrundsmönster -->
                <div class="header-pattern position-absolute w-100 h-100"></div>

                <div class="position-relative z-2">
                    <div class="row align-items-center">
                        <div class="col-lg-8">
                            <div class="library-icon mb-3">
                                <div class="icon-wrapper">
                                    <i class="bi bi-collection"></i>
                                    <div class="icon-pulse"></div>
                                </div>
                            </div>

                            <h1 class="display-5 fw-bold mb-2 header-title">Bokbibliotek</h1>
                            <p class="text-muted mb-3 fs-5">Upptäck och hantera din kompletta boksamling</p>

                            <!-- Snabbstatistik -->
                            @if (Model.Statistics != null)
                            {
                                <div class="quick-stats d-flex flex-wrap gap-3">
                                    <div class="stat-item m-1">
                                        <i class="bi bi-collection mr-2"></i>
                                        <span class="stat-value">@Model.Statistics.TotalBooks</span>
                                        <span class="stat-label">Böcker</span>
                                    </div>
                                    <div class="stat-item m-1">
                                        <i class="bi bi-files mr-2"></i>
                                        <span class="stat-value">@Model.Statistics.TotalCopies</span>
                                        <span class="stat-label">Exemplar</span>
                                    </div>
                                    <div class="stat-item m-1">
                                        <i class="bi bi-check-circle mr-2"></i>
                                        <span class="stat-value">@Model.Statistics.AvailableCopies</span>
                                        <span class="stat-label">Tillgängliga</span>
                                    </div>
                                    <div class="stat-item m-1">
                                        <i class="bi bi-person mr-2"></i>
                                        <span class="stat-value">@Model.Statistics.TotalAuthors</span>
                                        <span class="stat-label">Författare</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="col-lg-4 text-lg-end">
                            <div class="header-actions d-flex flex-column gap-2">
                                <a asp-action="Create" class="btn btn-primary btn-lg m-1">
                                    <i class="bi bi-plus-circle mr-2"></i>
                                    Lägg till ny bok
                                </a>
                                <div class="export-actions d-flex gap-2">
                                    <a asp-action="ExportToCsv" class="btn btn-outline-success btn-sm m-1">
                                        <i class="bi bi-file-earmark-spreadsheet mr-1"></i>
                                        Exportera CSV
                                    </a>
                                    <a asp-action="ExportToJson" class="btn btn-outline-info btn-sm m-1">
                                        <i class="bi bi-filetype-json mr-1"></i>
                                        Exportera JSON
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Avancerad sök- och filtreringssektion -->
            <div class="search-filter-section mb-4">
                <form method="get" asp-action="Index" class="search-form">
                    <div class="row g-3">
                        <!-- Sökinput -->
                        <div class="col-md-4">
                            <div class="search-container">
                                <input type="text"
                                       name="search"
                                       value="@Model.SearchTerm"
                                       class="form-control search-input"
                                       placeholder="Sök böcker efter titel, författare eller ISBN..."
                                       id="searchInput">
                                <i class="bi bi-search search-icon"></i>
                                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                {
                                    <button type="button" class="clear-search" onclick="clearSearch()">
                                        <i class="bi bi-x"></i>
                                    </button>
                                }
                            </div>
                            <!-- Keyboard shortcut hint -->
                            <div class="keyboard-hint text-muted small mt-1">
                                <span class="d-none d-md-inline p-0 m-0">Tips: Använd</span>
                                <kbd>Ctrl/Cmd + K</kbd> för att fokusera och <kbd>Esc</kbd> för att rensa
                            </div>
                        </div>

                        <!-- Författarfilter -->
                        <div class="col-md-2">
                            <select name="authorId" class="form-control" onchange="this.form.submit()">
                                <option value="">Alla författare</option>
                                @if (Model.Authors != null)
                                {
                                    @foreach (var author in Model.Authors.Skip(1)) // Hoppa över "Alla författare" alternativet
                                    {
                                        <option value="@author.Value" selected="@author.Selected">@author.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Genrefilter -->
                        <div class="col-md-2">
                            <select name="genre" class="form-control" onchange="this.form.submit()">
                                <option value="">Alla genrer</option>
                                @if (Model.Genres != null)
                                {
                                    @foreach (var genre in Model.Genres.Skip(1)) // Hoppa över "Alla genrer" alternativet
                                    {
                                        <option value="@genre.Value" selected="@genre.Selected">@genre.Text</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Tillgänglighetsfilter -->
                        <div class="col-md-2">
                            <select name="available" class="form-control" onchange="this.form.submit()">
                                <option value="">Alla böcker</option>
                                <option value="true" selected="@(Model.AvailabilityFilter == true)">Tillgängliga</option>
                                <option value="false" selected="@(Model.AvailabilityFilter == false)">Otillgängliga</option>
                            </select>
                        </div>

                        <!-- Sorteringsalternativ -->
                        <div class="col-md-2">
                            <select name="sort" class="form-control" onchange="this.form.submit()">
                                <option value="title" selected="@(sortBy == "title")">Titel A-Ö</option>
                                <option value="title_desc" selected="@(sortBy == "title_desc")">Titel Ö-A</option>
                                <option value="author" selected="@(sortBy == "author")">Författare A-Ö</option>
                                <option value="author_desc" selected="@(sortBy == "author_desc")">Författare Ö-A</option>
                                <option value="date" selected="@(sortBy == "date")">Äldsta först</option>
                                <option value="date_desc" selected="@(sortBy == "date_desc")">Nyaste först</option>
                                <option value="copies" selected="@(sortBy == "copies")">Färst exemplar</option>
                                <option value="copies_desc" selected="@(sortBy == "copies_desc")">Flest exemplar</option>
                            </select>
                        </div>
                    </div>

                    <!-- Dolda inputs för sidnumrering -->
                    <input type="hidden" name="page" value="@Model.CurrentPage">
                    <input type="hidden" name="pageSize" value="@Model.PageSize">
                </form>
            </div>

            <!-- Resultatinfo -->
            <div class="results-info mb-4 d-flex justify-content-between align-items-center">
                <div class="results-text mx-4">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span>Hittade <strong>@Model.TotalRecords</strong> böcker som matchar "<em>@Model.SearchTerm</em>"</span>
                    }
                    else
                    {
                        <span>Visar <strong>@Model.TotalRecords</strong> böcker</span>
                    }
                </div>

                <div class="view-options">
                    <div class="btn-group" role="group">
                        <button type="button" class="btn btn-outline-secondary active" onclick="setGridView()">
                            <i class="bi bi-grid-3x3-gap"></i>
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="setListView()">
                            <i class="bi bi-list"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Bokrutnät -->
            <div class="books-container" id="booksContainer">
                @if (books != null && books.Any())
                {
                    <div class="books-grid" id="booksGrid">
                        @foreach (var book in books)
                        {
                            <div class="book-card" data-book-id="@book.Id">
                                <div class="book-card-inner">
                                    <!-- Bokomslag -->
                                    <div class="book-cover">
                                        <img src="@(book.ImageBinary ?? "/uploads/9780555816023.png")"
                                             alt="@book.Title"
                                             class="cover-image"
                                             onerror="this.src='/uploads/9780555816023.png'">

                                        <!-- Statusmärkning -->
                                        <div class="status-badge @(book.IsAvailable ? "available" : "unavailable")">
                                            <i class="bi @(book.IsAvailable ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                                            @(book.IsAvailable ? "Tillgänglig" : "Otillgänglig")
                                        </div>

                                        <!-- Snabbåtgärder Overlay -->
                                        <div class="quick-actions">
                                            <a asp-action="Details" asp-route-id="@book.Id"
                                               class="action-btn view-btn m-1" title="Visa detaljer">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@book.Id"
                                               class="action-btn edit-btn m-1" title="Redigera bok">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button onclick="addBookCopy(@book.Id, '@Html.Raw(book.Title.Replace("'", "\\'"))')"
                                                    class="action-btn add-btn m-1" title="Lägg till exemplar">
                                                <i class="bi bi-plus-circle"></i>
                                            </button>
                                            <button onclick="downloadCover(@book.Id)"
                                                    class="action-btn download-btn m-1" title="Ladda ner omslag">
                                                <i class="bi bi-download"></i>
                                            </button>
                                            <button onclick="generateReport(@book.Id)"
                                                    class="action-btn report-btn m-1" title="Generera rapport">
                                                <i class="bi bi-file-text"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Bokinfo -->
                                    <div class="book-info">
                                        <h3 class="book-title" title="@book.Title">@book.Title</h3>
                                        @if (!string.IsNullOrEmpty(book.Subtitle))
                                        {
                                            <p class="book-subtitle">@book.Subtitle</p>
                                        }
                                        <p class="book-author">av @(book.Author?.Name ?? "Okänd författare")</p>

                                        <div class="book-meta">
                                            <span class="meta-item">
                                                <i class="bi bi-bookmark mr-1"></i>
                                                @book.ISBN
                                            </span>
                                            @if (!string.IsNullOrEmpty(book.Genre))
                                            {
                                                <span class="meta-item">
                                                    <i class="bi bi-tag mr-1"></i>
                                                    @book.Genre
                                                </span>
                                            }
                                            @if (book.Pages.HasValue)
                                            {
                                                <span class="meta-item">
                                                    <i class="bi bi-file-text mr-1"></i>
                                                    @book.Pages sidor
                                                </span>
                                            }
                                        </div>

                                        <!-- Bokstatistik -->
                                        <div class="book-stats">
                                            <div class="stat-group">
                                                <div class="stat-item">
                                                    <i class="bi bi-files"></i>
                                                    <span>@book.TotalCopies exemplar</span>
                                                </div>
                                                <div class="stat-item">
                                                    <i class="bi bi-check-circle"></i>
                                                    <span class="@(book.AvailableCopies > 0 ? "text-success" : "text-danger")">
                                                        @book.AvailableCopies tillgängliga
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                    <!-- Åtgärdsknappar -->
                                    <div class="book-actions">
                                        <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-primary btn-sm text-nowrap">
                                            <i class="bi bi-eye mr-1"></i>
                                            Visa detaljer
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-pencil mr-1"></i>
                                            Redigera
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Sidnumrering -->
                    @if (Model.TotalPages > 1)
                    {
                        <nav class="pagination-nav mt-5">
                            <ul class="pagination justify-content-center">
                                <!-- Föregående knapp -->
                                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                        Föregående
                                    </a>
                                </li>

                                <!-- Sidnummer -->
                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@GetPageUrl(i)">@i</a>
                                    </li>
                                }

                                <!-- Nästa knapp -->
                                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="@GetPageUrl(Model.CurrentPage + 1)">
                                        Nästa
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>

                            <!-- Sidinfo -->
                            <div class="page-info text-center mt-3">
                                <small class="text-muted">
                                    Sida @Model.CurrentPage av @Model.TotalPages
                                    (@Model.TotalRecords böcker totalt)
                                </small>
                            </div>
                        </nav>
                    }
                }
                else
                {
                    <!-- Tomt tillstånd -->
                    <div class="empty-state text-center py-5">
                        <div class="empty-content">
                            <i class="bi bi-book fs-1 text-muted"></i>
                            <h3 class="mt-3">Inga böcker hittades</h3>
                            @if (!string.IsNullOrEmpty(Model.SearchTerm))
                            {
                                <p class="text-muted">Inga böcker matchar din sökning "<em>@Model.SearchTerm</em>"</p>
                                <button class="btn btn-outline-primary" onclick="clearSearch()">
                                    <span class="row justify-content-center align-items-center m-1">
                                        <i class="bi bi-x-circle m-2"></i>
                                        Rensa sökning
                                    </span>
                                </button>
                            }
                            else
                            {
                                <p class="text-muted">Börja bygga ditt bibliotek genom att lägga till din första bok</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <span class="row justify-content-center align-items-center m-1">
                                        <i class="bi bi-plus-circle m-2"></i>
                                        Lägg till din första bok
                                    </span>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetPageUrl(int page)
    {
        var routeValues = new Dictionary<string, object?>
        {
            { "page", page },
            { "pageSize", Model.PageSize },
            { "search", Model.SearchTerm },
            { "authorId", Model.AuthorFilter },
            { "genre", Model.GenreFilter },
            { "available", Model.AvailabilityFilter },
            { "sort", ViewBag.SortBy }
        };

        var filteredRouteValues = routeValues.Where(x => x.Value != null).ToDictionary(x => x.Key, x => x.Value);
        var url = Url.Action("Index", "Books", filteredRouteValues);
        return url ?? string.Empty;
    }
}

@section Scripts {
    <script>
         // Konfigurera toastr
         toastr.options = {
             closeButton: true,
             newestOnTop: true,
             progressBar: true,
             positionClass: "toast-top-right",
             timeOut: "3500",
             showMethod: "fadeIn",
             hideMethod: "fadeOut"
         };

         // Globala variabler
         let currentPage = @Model.CurrentPage;
         let totalPages = @Model.TotalPages;

         // ====================================================================
         // SÖKFUNKTIONALITET
         // ====================================================================

         function clearSearch() {
             const url = new URL(window.location);
             url.searchParams.delete('search');
             url.searchParams.set('page', '1'); // Återställ till första sidan
             window.location.href = url.toString();
         }

        // Tangentbordsgenvägar
         document.addEventListener('keydown', function(e) {
             // Convert key to lowercase for case-insensitive comparison
             const keyPressed = e.key.toLowerCase();

             // Ctrl/Cmd + K to focus search (works with any Caps Lock state)
             if ((e.ctrlKey || e.metaKey) && keyPressed === 'k') {
                 e.preventDefault();
                 document.getElementById('searchInput').focus();
             }

             // Escape to clear search (works with any Caps Lock state)
             if (keyPressed === 'escape') {
                 const searchInput = document.getElementById('searchInput');
                 if (searchInput.value) {
                     clearSearch();
                 }
             }
         });

         // ====================================================================
         // BOKÅTGÄRDER
         // ====================================================================

         async function addBookCopy(bookId, bookTitle) {
             const result = await Swal.fire({
                 title: 'Lägg till bokexemplar',
                 html: `
                     <p>Lägg till ett nytt exemplar av "<strong>${bookTitle}</strong>"?</p>
                     <div class="row g-3 mt-3">
                         <div class="col-6">
                             <label class="form-label">Skick:</label>
                             <select id="copyCondition" class="form-control">
                                 <option value="New">Ny</option>
                                 <option value="Excellent">Utmärkt</option>
                                 <option value="Good" selected>Bra</option>
                                 <option value="Fair">Godtagbar</option>
                                 <option value="Poor">Dålig</option>
                             </select>
                         </div>
                         <div class="col-6">
                             <label class="form-label">Plats:</label>
                             <input type="text" id="copyLocation" class="form-control" placeholder="t.ex. A-101">
                         </div>
                         <div class="col-12">
                             <label class="form-label">Inköpspris:</label>
                             <input type="number" id="copyPrice" class="form-control" step="0.01" min="0" placeholder="0.00">
                         </div>
                     </div>
                 `,
                 icon: 'question',
                 showCancelButton: true,
                 confirmButtonColor: '#28a745',
                 cancelButtonColor: '#6c757d',
                 confirmButtonText: '<i class="bi bi-plus-circle"></i> Lägg till exemplar',
                 cancelButtonText: 'Avbryt',
                 preConfirm: () => {
                     return {
                         condition: document.getElementById('copyCondition').value,
                         location: document.getElementById('copyLocation').value,
                         price: document.getElementById('copyPrice').value
                     };
                 }
             });

             if (result.isConfirmed) {
                 try {
                     const formData = new FormData();
                     formData.append('condition', result.value.condition);
                     formData.append('location', result.value.location);
                     if (result.value.price) {
                         formData.append('purchasePrice', result.value.price);
                     }

                     const response = await fetch(`/Books/AddBookCopy/${bookId}`, {
                         method: 'POST',
                         headers: {
                             'RequestVerificationToken': getAntiForgeryToken()
                         },
                         body: formData
                     });

                     const data = await response.json();

                     if (data.success) {
                         toastr.success(data.message);
                         // Ladda om sidan för att visa uppdaterad statistik
                         setTimeout(() => window.location.reload(), 1000);
                     } else {
                         toastr.error(data.message);
                     }
                 } catch (error) {
                     console.error('Fel vid tillägg av bokexemplar:', error);
                     toastr.error('Misslyckades att lägga till exemplar. Försök igen.');
                 }
             }
         }

         async function downloadCover(bookId) {
             try {
                 const response = await fetch(`/Books/DownloadCover/${bookId}`);
                 if (response.ok) {
                     const blob = await response.blob();
                     const url = window.URL.createObjectURL(blob);
                     const a = document.createElement('a');
                     a.href = url;
                     a.download = `bok_${bookId}_omslag.jpg`;
                     document.body.appendChild(a);
                     a.click();
                     document.body.removeChild(a);
                     window.URL.revokeObjectURL(url);
                     toastr.success('Omslag nedladdat framgångsrikt');
                 } else {
                     toastr.error('Misslyckades att ladda ner omslag');
                 }
             } catch (error) {
                 console.error('Fel vid nedladdning av omslag:', error);
                 toastr.error('Misslyckades att ladda ner omslag');
             }
         }

         async function generateReport(bookId) {
             try {
                 const response = await fetch(`/Books/GenerateBookReport/${bookId}`);
                 if (response.ok) {
                     const blob = await response.blob();
                     const url = window.URL.createObjectURL(blob);
                     const a = document.createElement('a');
                     a.href = url;
                     a.download = `bokrapport_${bookId}.txt`;
                     document.body.appendChild(a);
                     a.click();
                     document.body.removeChild(a);
                     window.URL.revokeObjectURL(url);
                     toastr.success('Rapport genererad framgångsrikt');
                 } else {
                     toastr.error('Misslyckades att generera rapport');
                 }
             } catch (error) {
                 console.error('Fel vid rapportgenerering:', error);
                 toastr.error('Misslyckades att generera rapport');
             }
         }

         // ====================================================================
         // VYOMKOPPLARE
         // ====================================================================

         function setGridView() {
             document.getElementById('booksContainer').className = 'books-container';
             document.getElementById('booksGrid').className = 'books-grid';

             // Uppdatera knappstatus
             document.querySelectorAll('.view-options .btn').forEach(btn => btn.classList.remove('active'));
             event.target.closest('.btn').classList.add('active');
         }

         function setListView() {
             document.getElementById('booksContainer').className = 'books-container list-view';
             document.getElementById('booksGrid').className = 'books-list';

             // Uppdatera knappstatus
             document.querySelectorAll('.view-options .btn').forEach(btn => btn.classList.remove('active'));
             event.target.closest('.btn').classList.add('active');
         }

         // ====================================================================
         // HJÄLPFUNKTIONER
         // ====================================================================

         function getAntiForgeryToken() {
             const token = document.querySelector('input[name="__RequestVerificationToken"]');
             return token ? token.value : '';
         }

         // ====================================================================
         // INITIALISERING
         // ====================================================================

         document.addEventListener('DOMContentLoaded', function() {
             // Animera bokkort vid laddning
             const bookCards = document.querySelectorAll('.book-card');
             bookCards.forEach((card, index) => {
                 setTimeout(() => {
                     card.classList.add('loaded');
                 }, index * 50);
             });

             // Visa framgångsmeddelande om omdirigerad från skapa/redigera
             @if (TempData["Success"] != null)
             {
                                         <text>toastr.success('@TempData["Success"]');</text>
             }

             @if (TempData["Error"] != null)
             {
                                         <text>toastr.error('@TempData["Error"]');</text>
             }

             // Tangentbordsgenvägar
             document.addEventListener('keydown', function(e) {
                 // Ctrl/Cmd + K för att fokusera sök
                 if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                     e.preventDefault();
                     document.getElementById('searchInput').focus();
                 }

                 // Escape för att rensa sökning
                 if (e.key === 'Escape') {
                     const searchInput = document.getElementById('searchInput');
                     if (searchInput.value) {
                         clearSearch();
                     }
                 }
             });
         });
    </script>
}

<style>
    /* Header Styling */
    .books-header {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(147, 51, 234, 0.1) 100%);
        border-radius: var(--radius-xl);
        padding: 3rem 2rem;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .header-pattern {
        background: radial-gradient(circle at 20% 50%, rgba(59, 130, 246, 0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(147, 51, 234, 0.1) 0%, transparent 50%), radial-gradient(circle at 40% 80%, rgba(16, 185, 129, 0.1) 0%, transparent 50%);
    }

    .header-title {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Biblioteksikon */
    .library-icon {
        position: relative;
        display: inline-block;
    }

    .icon-wrapper {
        position: relative;
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        border-radius: 50%;
        display: flex;
